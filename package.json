{
  "name": "apeiron",
  "private": true,
  "version": "0.0.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "predev": "npm run build:deps",
    "build": "npm run build:deps && tsc -b && vite build",
    "build:deps": "npm run build:schema && npm run build:wasm",
    "build:schema": "node scripts/compileLayoutSchema.js",
    "build:wasm": "cd rust-math && wasm-pack build --target web --out-dir ../src/engine/math-workers/wasm",
    "pretest": "npm run build:deps",
    "test": "npm run test:engine && npm run test:ui",
    "test:engine": "deno test --unstable-webgpu --allow-read --allow-env --allow-write --no-check tests/engine.deno.ts tests/engine/ComputeUnit.deno.ts",
    "test:ui": "vitest run",
    "test:update": "UPDATE_SNAPSHOTS=true deno test --unstable-webgpu --allow-read --allow-env --allow-write --no-check tests/engine.deno.ts tests/engine/ComputeUnit.deno.ts",
    "lint": "eslint .",
    "lint:wgsl": "deno run --unstable-webgpu --allow-read scripts/lintWgsl.ts",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/web-worker": "^4.1.4",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.4",
    "wasm-pack": "^0.14.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ],
    "*.wgsl": [
      "npm run lint:wgsl"
    ]
  }
}
